# ============================================================
#  .env.example — Lending System Environment Configuration
#  ============================================================
# 
# 1. Copy this file to .env
# 2. Fill in your actual values
# 3. NEVER commit .env to version control!
#

# ── Database Configuration ─────────────────────────────────────
DB_HOST=localhost
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASS=your_secure_password
DB_CHARSET=utf8mb4

# ── Application Settings ─────────────────────────────────────────
APP_NAME="Lending System"
APP_URL=http://localhost/lending_system
APP_VERSION=1.0.0
APP_ENV=production

# ── Security Settings ────────────────────────────────────────────
SESSION_LIFETIME=604800
HASH_COST=12
CSRF_TOKEN_SECRET=your_random_secret_key_here_min_32_chars

# ── File Upload Settings ───────────────────────────────────────
UPLOAD_MAX_MB=5
UPLOAD_ALLOWED_TYPES=a:5:{i:0;s:9:"image/jpeg";i:1;s:8:"image/jpg";i:2;s:9:"image/png";i:3;s:9:"image/gif";i:4;s:15:"application/pdf";}

# ── Email Settings ─────────────────────────────────────────────
MAIL_ENABLED=true
MAIL_FROM=no-reply@yourdomain.com
MAIL_FROM_NAME="Lending System"
MAIL_SMTP_HOST=
MAIL_SMTP_PORT=587
MAIL_SMTP_USER=
MAIL_SMTP_PASS=
MAIL_SMTP_ENCRYPTION=tls

# ── Loan Settings ────────────────────────────────────────────────
MAX_LOAN_AMOUNT=10000
MIN_LOAN_AMOUNT=5000
LOAN_INTEREST_RATE=0.03
LOAN_PENALTY_RATE=0.02
LOAN_DUE_DAYS=28

# ── Savings Settings ───────────────────────────────────────────
SAVINGS_MAX=100000
SAVINGS_MIN_DEPOSIT=100
SAVINGS_MAX_DEPOSIT=1000
SAVINGS_MIN_WITHDRAWAL=500
SAVINGS_MAX_WITHDRAWAL=5000
SAVINGS_MAX_WITHDRAWALS_PER_DAY=5

# ── Account Settings ───────────────────────────────────────────
PREMIUM_MAX_SLOTS=50
MONEY_BACK_PERCENTAGE=0.02

# ── Development Settings ───────────────────────────────────────
DEBUG_MODE=false
ERROR_REPORTING=22519

# ── Rate Limiting ────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_WINDOW=60
LOGIN_RATE_LIMIT=5
LOGIN_RATE_WINDOW=300

# ── Input Validation ─────────────────────────────────────────────
MAX_INPUT_LENGTH=255
MAX_TEXTAREA_LENGTH=5000
MAX_UPLOAD_SIZE=5242880
